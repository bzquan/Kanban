<Page x:Class="Kanban.BoardListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Kanban"
      xmlns:p = "clr-namespace:Kanban.Properties"
      xmlns:vm="clr-namespace:Kanban.ViewModel"
      xmlns:dd="clr-namespace:DragAndDropLib"
      mc:Ignorable="d" 
      x:Name="rootPage"
      d:DataContext="{d:DesignInstance Type=vm:BoardListViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="800" d:DesignWidth="1100"
      Title="KanbanList" Loaded="Page_Loaded">
    
    <Page.Resources>
        <Image x:Key="Add" Source="/Kanban;component/images/add.png"/>
        <Image x:Key="AddProcessStep" Source="/Kanban;component/images/add.png"/>
        <Image x:Key="Refresh" Source="/Kanban;component/images/refresh.png"/>
        <Image x:Key="About" Source="/Kanban;component/images/about.png" />
        <BitmapImage x:Key="Admin" UriSource="/Kanban;component/images/admin.png"/>
        <BitmapImage x:Key="ArrowRight" UriSource="/Kanban;component/images/arrow-right.png"/>
        <BitmapImage x:Key="Save" UriSource="/Kanban;component/images/save.png"/>
        <BitmapImage x:Key="Remove" UriSource="/Kanban;component/images/remove.png"/>
        <local:SingleLineTextConverter x:Key="TextConverter"/>
        <local:ColorNameToBrushConverter x:Key="ColorNameToBrushConverter"/>
        <local:HighlighterConverter x:Key="HighlighterConverter"/>
        <local:EnumBooleanConverter x:Key="enumBooleanConverter" />
        
        <Style x:Key="CellHighlighterStyle">
            <Setter Property="DataGrid.Background">
                <Setter.Value>
                    <MultiBinding
                        Converter="{StaticResource HighlighterConverter}" >
                        <MultiBinding.Bindings>
                            <Binding RelativeSource="{RelativeSource Self}"/>
                            <Binding Path="Row" Mode="OneWay"/>
                        </MultiBinding.Bindings>
                    </MultiBinding>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HighlightTextBox" TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="White" />
                </Trigger>
                <Trigger Property="IsFocused" Value="False">
                    <Setter Property="Background" Value="LightCyan" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <DataTemplate x:Key="boardListBoxDataTemplate" DataType="{x:Type vm:Board}">
            <Border Margin="5" BorderThickness="2" BorderBrush="SteelBlue" 
                    Background="{Binding RelativeSource=
                          {
                             RelativeSource 
                             Mode=FindAncestor, 
                             AncestorType={x:Type ListBoxItem}
                          }, 
                          Path=Background
                         }"
                    CornerRadius="4">
                <StackPanel Orientation="Vertical" Width="300" Margin="5,10,5,10">
                    <StackPanel.Resources>
                        <Style TargetType="{x:Type FrameworkElement}">
                            <Setter Property="TextBlock.Foreground" Value="Black" />
                        </Style>
                        <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type FrameworkElement}}" />
                        <Style TargetType="{x:Type Label}" BasedOn="{StaticResource {x:Type FrameworkElement}}" />
                    </StackPanel.Resources>
                    <StackPanel.Background>
                        <SolidColorBrush Color="Lime"/>
                    </StackPanel.Background>
                    <TextBlock Text="{Binding Path=Title, StringFormat={x:Static p:Resources.Board_NameFormat}}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Path=Description, Converter={StaticResource TextConverter}, StringFormat={x:Static p:Resources.Board_DetailFormat}}" TextTrimming="CharacterEllipsis" />
                    <DockPanel>
                        <Button x:Name="gotoBoardButton" DockPanel.Dock="Left" Background="{x:Null}" BorderBrush="{x:Null}" HorizontalContentAlignment="Left"  Command="{Binding Path=GotoBoardPageCommand}" ToolTip="{x:Static p:Resources.ToolTip_OpenBoard}">
                            <StackPanel>
                                <Image Width="24" Height="24" Source="{StaticResource ArrowRight}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="deleteBoardButton" DockPanel.Dock="Right"  Background="{x:Null}" BorderBrush="{x:Null}" HorizontalContentAlignment="Right" HorizontalAlignment="Right" Command="{Binding Path=DeleteBoardCommand, Mode=OneTime}" ToolTip="{x:Static p:Resources.ToolTip_Delete}">
                            <StackPanel>
                                <Image Width="24" Height="24" Source="{StaticResource Remove}" />
                            </StackPanel>
                        </Button>
                    </DockPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="processStepListBoxDataTemplate" DataType="{x:Type vm:ProcessStep}">
            <Border Margin="2" BorderThickness="2" BorderBrush="Blue" 
                    Background="{Binding RelativeSource=
                          {
                             RelativeSource 
                             Mode=FindAncestor, 
                             AncestorType={x:Type ListBoxItem}
                          }, 
                          Path=Background
                         }"
                    CornerRadius="4">
                <Grid Background="{Binding Path=LabelColor}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Image Width="14" Height="14"  Margin="5, 0, 5, 0" Source="{Binding SeqNoImage}"/>
                        <TextBox Text ="{Binding Name}" Style="{StaticResource HighlightTextBox}" Width="150" VerticalAlignment="Center" TextWrapping="NoWrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="WIP" Margin="5, 0, 5, 0" VerticalAlignment="Center"/>
                        <TextBox Text ="{Binding WIPTitle}" Style="{StaticResource HighlightTextBox}" Width="60" VerticalAlignment="Center" TextWrapping="NoWrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="Done" Margin="5, 0, 5, 0" VerticalAlignment="Center" />
                        <TextBox Text ="{Binding DoneTitle}" Style="{StaticResource HighlightTextBox}"  Width="60" VerticalAlignment="Center" TextWrapping="NoWrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                        <TextBlock Text="{x:Static p:Resources.Process_MetricsBegin}" Margin="5, 0, 5, 0" VerticalAlignment="Center" />
                        <RadioButton VerticalAlignment="Center" GroupName="StartOfCycleTime" IsChecked="{Binding Path=IsStartOfCycleTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                        <TextBlock Text="{x:Static p:Resources.Process_MetricsEnd}" Margin="5, 0, 5, 0" VerticalAlignment="Center" />
                        <RadioButton VerticalAlignment="Center" GroupName="EndOfCycleTime" IsChecked="{Binding Path=IsEndOfCycleTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="5" Orientation="Horizontal">
                        <Button x:Name="deleteProcessStepButton" Background="{x:Null}" VerticalAlignment="Center" BorderBrush="{x:Null}" Command="{Binding ElementName=rootPage, Path=DataContext.ProcessViewModel.DeleteProcessStepCommand, Mode=OneTime}" CommandParameter="{Binding}" ToolTip="削除" >
                            <StackPanel Width="30">
                                <Image HorizontalAlignment="Right" VerticalAlignment="Center"  Width="14" Height="14" Source="{StaticResource Remove}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <DockPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" >
            <ToolBar x:Name="toolBar" VerticalAlignment="Top" DockPanel.Dock="Top">
                <Button x:Name="addButton"  Width="32" Height="32" VerticalAlignment="Center" Command="{Binding Path=AddBoardCommand, Mode=OneTime}" ToolTip="{x:Static p:Resources.ToolTip_AddBoard}">
                    <DynamicResource ResourceKey="Add"/>
                </Button>
                <Button x:Name="refreshButton"  Width="32" Height="32" VerticalAlignment="Center" Command="{Binding Path=RefreshCommand, Mode=OneTime}" ToolTip="{x:Static p:Resources.ToolTip_Refresh}">
                    <DynamicResource ResourceKey="Refresh"/>
                </Button>
                <Button x:Name="adminButton" Width="32" Height="32" VerticalAlignment="Center" ToolTip="{x:Static p:Resources.ToolTip_GotoSetting}" Command="{Binding Path=GotoSystemSettingCommand, Mode=OneTime}" >
                    <Image Source="{Binding Path=GotoSystemSettingPageImage, FallbackValue={StaticResource Admin}}"/>
                </Button>
                <Button x:Name="aboutButton"
                        Width="32"
                        Height="32"
                        VerticalAlignment="Center"
                        ToolTip="{x:Static p:Resources.ToolTip_ReleaseNote}"
                        Click="OnHelp">
                    <DynamicResource ResourceKey="About" />
                </Button>
            </ToolBar>
        </DockPanel>
        <DockPanel Grid.Row="1" Grid.Column="0" MinWidth="300" >
            <TextBlock Text="{x:Static p:Resources.Main_Title}" Margin="10,0,0,0" DockPanel.Dock="Top" />
            <dd:ItemsControlDragDropDecorator DockPanel.Dock="Bottom"  
                    ItemType="{x:Type vm:Board}" DataTemplate="{StaticResource boardListBoxDataTemplate}" >
                <ListBox x:Name="BoardListBox" Margin="10" ItemsSource="{Binding BoardList}" SelectedItem="{Binding SelectedBoard}" ItemTemplate="{StaticResource boardListBoxDataTemplate}" >
                    <ListBox.ItemContainerStyle>
                      <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <EventSetter Event="MouseDoubleClick" Handler="OnDoubleClicked"/>
                            <Setter Property="Control.Padding" Value="0"></Setter>
                            <Style.Triggers>
                                <Trigger Property="ListBoxItem.IsSelected" Value="True">
                                    <Setter Property="ListBoxItem.Background" Value="SkyBlue" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </dd:ItemsControlDragDropDecorator>
        </DockPanel>
        <Grid Grid.Row="1" Grid.Column="1" Margin="0, 0, 5, 10" >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Content="{x:Static p:Resources.Main_KanbanName}"/>
            <TextBox Grid.Row="1" Text="{Binding SelectedBoard.Title}" />
            <Label Grid.Row="2" Content="{x:Static p:Resources.Main_KanbanDetail}"/>
            <TextBox Grid.Row="3" Height="50" AcceptsReturn="True" Grid.Column="3" Text="{Binding SelectedBoard.Description}" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" />
            <StackPanel Grid.Row="4" Orientation="Horizontal">
                <Label Content="{x:Static p:Resources.Main_Process}"/>
                <Button x:Name="addProcessStepButton"  Width="24" Height="24" VerticalAlignment="Center" Command="{Binding Path=AddProcessStepCommand, Mode=OneTime}" ToolTip="{x:Static p:Resources.ToolTip_AddProcessStep}">
                    <local:AutoGreyableImage Source="/Kanban;component/images/add.png"/>
                </Button>
            </StackPanel>
            <ScrollViewer Grid.Row="5" HorizontalAlignment="Left" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Height="220">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <dd:ItemsControlDragDropDecorator DockPanel.Dock="Bottom"  
                    ItemType="{x:Type vm:ProcessStep}" DataTemplate="{StaticResource processStepListBoxDataTemplate}" >
                        <ListBox Margin="2" MinWidth="500" ItemsSource="{Binding Path=ProcessViewModel.ProcessSteps}" ItemTemplate="{StaticResource processStepListBoxDataTemplate}" >
                            <ListBox.ItemContainerStyle>
                                <Style>
                                    <Setter Property="Control.Padding" Value="0"></Setter>
                                    <Style.Triggers>
                                        <Trigger Property="ListBoxItem.IsSelected" Value="True">
                                            <Setter Property="ListBoxItem.Background" Value="SkyBlue" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </dd:ItemsControlDragDropDecorator>
                    <TextBlock x:Name="KanbanPractices" Margin="10,0,0,0" Background="LightYellow">
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="TextBlock.Loaded">
                                <BeginStoryboard>
                                    <Storyboard Storyboard.TargetProperty="(TextBlock.Background).(SolidColorBrush.Color)">
                                        <ColorAnimation  RepeatBehavior="Forever"
                                                     AutoReverse="True"
                                                     FillBehavior="Stop"
                                                     From="Yellow"
                                                     To="Orange"
                                                     By="LightYellow"
                                                     Duration="0:0:10" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers> 
                    <Run FontSize="16" FontFamily="{Binding KanbanPracticeFontFamily}" Foreground="DarkBlue" Text="{x:Static p:Resources.Kanban_PracticeTitle}"/>
                    <LineBreak/>
                    <LineBreak/>
                    <Run FontSize="14" FontFamily="{Binding KanbanPracticeFontFamily}" Foreground="ForestGreen" Text="{x:Static p:Resources.Kanban_Practice1}"/>
                    <LineBreak/>
                    <Run FontSize="14" FontFamily="{Binding KanbanPracticeFontFamily}" Foreground="DarkSlateGray" Text="{x:Static p:Resources.Kanban_Practice2}"/>
                    <LineBreak/>
                    <Run FontSize="14" FontFamily="{Binding KanbanPracticeFontFamily}" Foreground="ForestGreen" Text="{x:Static p:Resources.Kanban_Practice3}"/>
                    <LineBreak/>
                    <Run FontSize="14" FontFamily="{Binding KanbanPracticeFontFamily}" Foreground="DarkSlateGray" Text="{x:Static p:Resources.Kanban_Practice4}"/>
                    <LineBreak/>
                    <Run FontSize="14" FontFamily="{Binding KanbanPracticeFontFamily}" Foreground="ForestGreen" Text="{x:Static p:Resources.Kanban_Practice5}"/>
                    <LineBreak/>
                    <LineBreak/>
                    <Run FontSize="14" FontFamily="{Binding KanbanPracticeFontFamily}" Foreground="Black" FontStyle="Italic" Text="{x:Static p:Resources.Kanban_PracticeCycleTimeNote}"/>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
            <Label Grid.Row="6" Content="{x:Static p:Resources.Main_Developers}"/>
            <TextBox Grid.Row="7" Height="50" AcceptsReturn="True" Grid.Column="3" Text="{Binding SelectedBoard.Developers}" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" />

            <StackPanel Grid.Row="8" Margin="0,10,0,0" HorizontalAlignment="Left">
                <Border BorderBrush="DarkGray" BorderThickness="2">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton GroupName="MetricChartType" Margin="5,0,0,0" Content="{Binding Path=MetricChartType_CFD}" IsChecked="{Binding Path=MetricChartShowType, Converter={StaticResource enumBooleanConverter}, ConverterParameter=CumulativeFlowDiagram}" />
                        <RadioButton GroupName="MetricChartType" Margin="5,0,0,0" Content="{Binding Path=MetricChartType_Throughput}" IsChecked="{Binding Path=MetricChartShowType, Converter={StaticResource enumBooleanConverter}, ConverterParameter=Throughput}" />
                        <RadioButton GroupName="MetricChartType" Margin="5,0,0,0" Content="{Binding Path=MetricChartType_CycleTimeDistribution}" IsChecked="{Binding Path=MetricChartShowType, Converter={StaticResource enumBooleanConverter}, ConverterParameter=CycleTimeDistribution}" />
                        <RadioButton GroupName="MetricChartType" Margin="5,0,0,0" Content="{Binding Path=MetricChartType_BugsAndBlocked}" IsChecked="{Binding Path=MetricChartShowType, Converter={StaticResource enumBooleanConverter}, ConverterParameter=BugsAndBlocked}" />
                        <RadioButton GroupName="MetricChartType" Margin="5,0,0,0" Content="{Binding Path=MetricChartType_TeamVelocity}" IsChecked="{Binding Path=MetricChartShowType, Converter={StaticResource enumBooleanConverter}, ConverterParameter=TeamVelocity}" />
                    </StackPanel>
                </Border>
            </StackPanel>
            <ScrollViewer Grid.Row="9" x:Name="scrollViewerOfCanvas" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <local:DrawingCanvas4Metrics x:Name="canvas4MetricsCharts" Height="200" Width="400" ClipToBounds="True" VerticalAlignment="Top" HorizontalAlignment="Left" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
